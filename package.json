{
  "name": "homelab-dashboard",
  "version": "1.0.0",
  "description": "HomeLab Dashboard with Tailwind CSS",
  "scripts": {
    "build:css": "tailwindcss -i ./static/src/input.css -o ./static/css/output.css --minify",
    "watch:css": "tailwindcss -i ./static/src/input.css -o ./static/css/output.css --watch",
    "dev": "concurrently --kill-others \"npm run watch:css\" \"python manage.py runserver\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "tailwindcss": "^4.3.0",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "concurrently": "^9.2.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "identity-obj-proxy": "^3.0.0"
  }
}